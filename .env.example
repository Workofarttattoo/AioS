# =============================================================================
# AI:OS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info
# Logging format: json, text
LOG_FORMAT=json
# Enable outbound HTTP calls from agents (set to true for production)
ALLOW_NETWORK_CALLS=false
# Run in forensic (read-only) mode — prevents state mutations
AGENTA_FORENSIC_MODE=false

# ---------------------------------------------------------------------------
# AI:OS Tool Launcher
# ---------------------------------------------------------------------------
# Authentication token for the tool launcher HTTP API.
# If empty, a random token is generated on startup.
AIOS_LAUNCHER_TOKEN=
# Port for the tool launcher (default: 7777)
AIOS_LAUNCHER_PORT=7777

# ---------------------------------------------------------------------------
# AI:OS API
# ---------------------------------------------------------------------------
# API key for external AI:OS integrations
AIOS_API_KEY=

# ---------------------------------------------------------------------------
# USPTO Patent API
# ---------------------------------------------------------------------------
USPTO_BASE_URL=https://patentcenter.uspto.gov/api
USPTO_TIMEOUT=30
# Authenticate via API key OR username/password (not both)
USPTO_API_KEY=
USPTO_USERNAME=
USPTO_PASSWORD=

# ---------------------------------------------------------------------------
# Stripe (payments)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Sentry (error tracking)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Cloud Providers (optional — for scalability agent)
# ---------------------------------------------------------------------------
# AWS
AWS_PROFILE=
# Google Cloud
GCP_PROJECT=
GOOGLE_CLOUD_PROJECT=
USE_VERTEX_AI=false
# Azure
AZURE_SUBSCRIPTION_ID=

# ---------------------------------------------------------------------------
# External APIs (optional)
# ---------------------------------------------------------------------------
# Alpha Vantage — financial data for oracle/forecasting
ALPHA_VANTAGE_KEY=

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
# Username for admin-level operations
ADMIN_USER=admin
